  "keyFeatures": [
    "Type-safe Drizzle ORM model runtime with progressive query building",
    "Type-safe request/response handlers with schema validation",
    "Structured logging with custom transports",
    "API aggregation and composition utilities",
    "Zod-based schema validation and type inference"
  ],
  "publicApiSurface": [
    "modelBuilder - Create type-safe Drizzle ORM models",
    "esc - Explicit where expression helper",
    "createHandler - Create type-safe API handlers",
    "createResponseHandler - Create structured response handlers",
    "createLogger - Create structured logger with transports",
    "createTransport - Create custom log transports",
    "checkSchema - Validate input against Zod schemas",
    "aggregate - Compose multiple API endpoints"
  ]
